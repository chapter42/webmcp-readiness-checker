{
  "manifest_version": 3,
  "name": "WebMCP Readiness Checker",
  "description": "Audit any page for WebMCP and AI agent-readiness. Scores pages 0-100 across 6 categories.",
  "version": "0.1.4",
  "permissions": ["sidePanel", "activeTab", "storage", "scripting", "webNavigation"],
  "host_permissions": ["<all_urls>"],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "WebMCP Readiness Checker"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
